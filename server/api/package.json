    "@logtail/winston": "^0.5.6",
    "@sentry/node": "^10.38.0",
    "adm-zip": "^0.5.17",
    "axios": "^1.15.2",
    "axios-cookiejar-support": "^5.0.5",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
